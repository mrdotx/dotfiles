[Unit]
Description=polybar status bars
After=picom.service
PartOf=i3.target

[Service]
Type=forking
WorkingDirectory=%h/.config/polybar
ExecStart=%h/Projects/repos/polybar/polybar.sh
ExecStop=%h/Projects/repos/polybar/polybar.sh --kill

[Install]
WantedBy=i3.target
